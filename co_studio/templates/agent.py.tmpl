"""${DOC_NAME} — generated by ConnectOnion Studio; safe to run standalone (python agent.py).

Standalone needs only the connectonion framework. Toolkit groups come from the
connectonion-studio package; when it is not installed the agent still hosts and
degrades gracefully to plain conversation (no tools).
"""
import os
from pathlib import Path

from connectonion import Agent, host

AGENT_DIR = Path(__file__).resolve().parent
CO_DIR = AGENT_DIR / ".co"
NAME = ${NAME_LITERAL}
MODEL = ${MODEL_LITERAL}
PORT = int(os.environ.get("CO_STUDIO_PORT", "${PORT}"))
TOOLKITS = ${TOOLKITS_LITERAL}
SYSTEM_PROMPT = ${SYSTEM_PROMPT_LITERAL}
TRUST = ${TRUST_LITERAL}   # who may connect: "open" | "careful" | "strict"


def _patch_get_ips() -> None:
    """Announce a few real IPv4s only (relay caps 10 endpoints) and never call the blocking ipify API."""
    import ifaddr
    import connectonion.network.announce as _announce

    if getattr(_announce.get_ips, "_co_studio_patched", False):
        return

    def _get_ips() -> list:
        preferred, rest = [], []
        for adapter in ifaddr.get_adapters():
            nic = str(adapter.name)
            if any(bad in nic for bad in ("utun", "awdl", "llw", "bridge", "vmnet", "vnic", "vbox", "tap", "tun")):
                continue  # VPN / VM / AirDrop adapters
            for ip in adapter.ips:
                if not isinstance(ip.ip, str):
                    continue  # IPv6 arrives as a tuple — IPv4 only
                if ip.ip.startswith("127.") or ip.ip.startswith("169.254."):
                    continue  # loopback dupe / link-local junk
                (preferred if nic in ("en0", "en1") else rest).append(ip.ip)
        seen = set()
        ips = [ip for ip in ["localhost", *preferred, *rest] if not (ip in seen or seen.add(ip))][:4]
        print(f"[co-studio] announce ips={','.join(ips)} endpoints={2 * len(ips)}", flush=True)
        return ips

    _get_ips._co_studio_patched = True
    _announce.get_ips = _get_ips


try:
    from co_studio.toolkits import resolve as _resolve_toolkits
except ImportError:  # ejected standalone run without connectonion-studio installed
    def _resolve_toolkits(names: list) -> tuple:
        return [], []

    if TOOLKITS:
        print(
            f"[co-studio] connectonion-studio not installed — toolkits {TOOLKITS} disabled, "
            "running as plain conversation",
            flush=True,
        )


def create_agent() -> Agent:
    """Fresh Agent per request — host() calls this for per-request isolation."""
    tools, plugins = _resolve_toolkits(TOOLKITS)
    return Agent(name=NAME, system_prompt=SYSTEM_PROMPT, tools=tools, plugins=plugins, model=MODEL)


if __name__ == "__main__":
    _patch_get_ips()
    host(create_agent, port=PORT, trust=TRUST, co_dir=CO_DIR)
